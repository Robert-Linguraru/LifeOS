@page "/habits"
@using LifeOS.Core.Entities
@using LifeOS.Core.Enums
@using LifeOS.Core.Interfaces
@using LifeOS.Infrastructure.Data
@using LifeOS.Infrastructure.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IXPService XpService
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthProvider
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]

<PageTitle>Habits — LifeOS</PageTitle>

<div class="page-header">
    <h1 class="page-title">Habits</h1>
    <div style="display:flex; gap:.75rem;">
        <button class="@(ShowArchived ? "btn-ghost" : "btn-primary")"
                @onclick="() => ShowArchived = false">
            Active
        </button>
        <button class="@(ShowArchived ? "btn-primary" : "btn-ghost")"
                @onclick="() => ShowArchived = true">
            Archived
        </button>
        @if (!ShowArchived)
        {
            <button class="btn-primary" @onclick="() => ShowForm = true">+ New Habit</button>
        }
    </div>
</div>

@if (ShowForm)
{
    <div class="card form-card">
        <h3>@(EditingHabit is null ? "New Habit" : "Edit Habit")</h3>
        <div class="form-grid">
            <input class="input" placeholder="Habit name" @bind="FormName" />
            <input class="input" placeholder="Description (optional)" @bind="FormDescription" />
            <select class="input" @bind="FormFrequency">
                @foreach (var f in Enum.GetValues<HabitFrequency>())
                {
                    <option value="@f">@f</option>
                }
            </select>
            <label class="checkbox-label">
                <input type="checkbox" @bind="FormIsQuantitative" /> Quantitative habit
            </label>
            @if (FormIsQuantitative)
            {
                <input class="input" type="number" placeholder="Target value" @bind="FormTargetValue" />
                <input class="input" placeholder="Unit (e.g. liters, pages)" @bind="FormUnit" />
            }
            <select class="input" @bind="FormEstimatedTime">
                @foreach (var t in Enum.GetValues<EstimatedTime>())
                {
                    <option value="@t">@t</option>
                }
            </select>
            <select class="input" @bind="FormFriction">
                @foreach (var f in Enum.GetValues<FrictionLevel>())
                {
                    <option value="@f">@f</option>
                }
            </select>
            <select class="input" @bind="FormQuestCategory">
                @foreach (var q in Enum.GetValues<QuestCategory>())
                {
                    <option value="@q">@q</option>
                }
            </select>
            <label>
                <input type="checkbox" @bind="FormReminderEnabled" />
                Enable Reminder
            </label>
            @if (FormReminderEnabled)
            {
                <input class="input"
                       type="datetime-local"
                       value="@FormReminderTimeString"
                       @onchange="(ChangeEventArgs e) => FormReminderTimeString = e.Value?.ToString() ?? string.Empty" />
            }
        </div>
        <div class="form-preview">
            <span class="badge badge-xp">⚡ ~@XpService.CalculateQuestXP(FormEstimatedTime, FormFriction) XP per completion</span>
        </div>
        <div class="form-actions">
            <button class="btn-primary" @onclick="SaveHabit">Save</button>
            <button class="btn-ghost" @onclick="CancelForm">Cancel</button>
        </div>
    </div>
}

<div class="habits-grid">
    @foreach (var habit in HabitEntities.Where(h => h.IsActive == !ShowArchived))
    {
        var loggedToday = TodayLogs.ContainsKey(habit.Id);
        var streak = Streaks.GetValueOrDefault(habit.Id);

        <div class="habit-card @(loggedToday ? "habit-done" : "")">
            <div class="habit-header">
                <span class="habit-name">@habit.Name</span>
                <span class="badge badge-streak">🔥 @(streak?.CurrentStreak ?? 0)</span>
            </div>
            @if (habit.IsQuantitative)
            {
                <span class="habit-target">Target: @habit.TargetValue @habit.Unit</span>
            }
            <div class="habit-meta">
                <span class="badge">@habit.Frequency</span>
                <span class="badge badge-xp">⚡ @XpService.CalculateQuestXP(habit.EstimatedTime, habit.FrictionLevel) XP</span>
            </div>
            <div class="habit-actions">
                @if (!ShowArchived)
                {
                    @if (!loggedToday)
                    {
                        <button class="btn-primary btn-sm" @onclick="() => LogHabit(habit)">
                            @(habit.IsQuantitative ? "Log" : "Done ✓")
                        </button>
                    }
                    else
                    {
                        <span class="completed-label">✓ Logged</span>
                    }
                    <button class="btn-icon" @onclick="() => EditHabit(habit)">✏</button>
                    <button class="btn-icon btn-danger" @onclick="() => ArchiveHabit(habit)">✕</button>
                }
                else
                {
                    <button class="btn-primary btn-sm" @onclick="() => UnarchiveHabit(habit)">↩ Restore</button>
                    <button class="btn-icon" @onclick="() => EditHabit(habit)">✏</button>
                    <button class="btn-icon btn-danger" @onclick="() => DeleteHabit(habit)">🗑</button>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Habit> HabitEntities = new();
    private Dictionary<Guid, HabitLog> TodayLogs = new();
    private Dictionary<Guid, StreakRecord> Streaks = new();
    private string? UserId;
    private bool ShowForm = false;
    private Habit? EditingHabit;
    private bool ShowArchived = false;
    private string FormName = "";
    private string? FormDescription;
    private HabitFrequency FormFrequency = HabitFrequency.Daily;
    private bool FormIsQuantitative = false;
    private decimal? FormTargetValue;
    private string? FormUnit;
    private bool FormReminderEnabled = false;
    private string FormReminderTimeString = "";
    private DateTime? FormReminderTime => string.IsNullOrEmpty(FormReminderTimeString)
        ? null
        : DateTime.TryParse(FormReminderTimeString, out var dt) ? dt : null;
    private EstimatedTime FormEstimatedTime = EstimatedTime.Under15m;
    private FrictionLevel FormFriction = FrictionLevel.Low;
    private QuestCategory FormQuestCategory = QuestCategory.Routines;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        UserId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        await LoadData();
    }

    private async Task LoadData()
    {
        if (UserId is null) return;
        var today = DateOnly.FromDateTime(DateTime.UtcNow);

        await using var db = await DbFactory.CreateDbContextAsync();

        HabitEntities = await db.HabitEntities
            .Where(h => h.UserId == UserId)
            .OrderBy(h => h.Name)
            .ToListAsync();

        TodayLogs = await db.HabitLogs
            .Where(l => l.UserId == UserId && l.Date == today)
            .ToDictionaryAsync(l => l.HabitId);

        Streaks = await db.StreakRecords
            .Where(s => s.UserId == UserId && s.SourceType == StreakSourceType.Habit)
            .ToDictionaryAsync(s => s.SourceId);
    }

    private async Task LogHabit(Habit habit)
    {
        if (UserId is null) return;
        var today = DateOnly.FromDateTime(DateTime.UtcNow);

        int xp = await XpService.AwardQuestXPAsync(UserId, habit.Id,
            habit.EstimatedTime, habit.FrictionLevel, XPSource.QuestCompletion);

        await using var db = await DbFactory.CreateDbContextAsync();

        db.HabitLogs.Add(new HabitLog
        {
            HabitId = habit.Id,
            UserId = UserId,
            Date = today,
            Completed = true,
            XPAwarded = xp
        });

        var notifs = await db.Notifications
        .Where(n => n.SourceEntityId == habit.Id && !n.IsRead)
        .ToListAsync();
            foreach (var n in notifs) n.IsRead = true;

        await db.SaveChangesAsync();
        await XpService.UpdateStreakAsync(UserId, habit.Id, StreakSourceType.Habit);
        await LoadData();
    }

    private async Task SaveHabit()
    {
        if (string.IsNullOrWhiteSpace(FormName) || UserId is null) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (EditingHabit is null)
            {

                var newHabit = new Habit
                {
                    UserId = UserId,
                    Name = FormName,
                    Description = FormDescription,
                    Frequency = FormFrequency,
                    IsQuantitative = FormIsQuantitative,
                    TargetValue = FormTargetValue,
                    Unit = FormUnit,
                    EstimatedTime = FormEstimatedTime,
                    FrictionLevel = FormFriction,
                    QuestCategory = FormQuestCategory
                };

                if (FormReminderEnabled && FormReminderTime.HasValue)
                {
                    newHabit.ReminderEnabled = true;
                    newHabit.ReminderTime = FormReminderTime.Value;

                    string jobId = await NotificationService.ScheduleReminderAsync(
                        UserId!,
                        $"🔁 Habit Reminder: {newHabit.Name}",
                        $"Don't forget to log \"{newHabit.Name}\" today.",
                        FormReminderTime.Value,
                        NotificationSourceType.HabitReminder,
                        newHabit.Id);

                    newHabit.HangfireJobId = jobId;
                }

                db.HabitEntities.Add(newHabit);
            }
            else
            {
                var tracked = await db.HabitEntities.FindAsync(EditingHabit.Id);
                if (tracked is not null)
                {
                    if (!string.IsNullOrEmpty(tracked.HangfireJobId))
                    {
                        await NotificationService.CancelReminderAsync(tracked.HangfireJobId);
                        tracked.HangfireJobId = null;
                    }
                    var staleNotifs = await db.Notifications
                        .Where(n => n.SourceEntityId == tracked.Id && !n.IsRead)
                        .ToListAsync();
                    foreach (var n in staleNotifs) n.IsRead = true;

                    tracked.Name = FormName;
                    tracked.Description = FormDescription;
                    tracked.Frequency = FormFrequency;
                    tracked.IsQuantitative = FormIsQuantitative;
                    tracked.TargetValue = FormTargetValue;
                    tracked.Unit = FormUnit;
                    tracked.EstimatedTime = FormEstimatedTime;
                    tracked.FrictionLevel = FormFriction;
                    tracked.QuestCategory = FormQuestCategory;

                    if (FormReminderEnabled && FormReminderTime.HasValue)
                    {
                        tracked.ReminderEnabled = true;
                        tracked.ReminderTime = FormReminderTime.Value;

                        string jobId = await NotificationService.ScheduleReminderAsync(
                            UserId!,
                            $"🔁 Habit Reminder: {tracked.Name}",
                            $"Don't forget to log \"{tracked.Name}\" today.",
                            FormReminderTime.Value,
                            NotificationSourceType.HabitReminder,
                            tracked.Id);

                        tracked.HangfireJobId = jobId;
                    }
                    else
                    {
                        tracked.ReminderEnabled = false;
                        tracked.ReminderTime = null;
                    }
                }
            }

            await db.SaveChangesAsync();
            CancelForm();
            await LoadData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SaveHabit error: {ex.Message} | {ex.InnerException?.Message}");
        }
    }

    private void EditHabit(Habit habit)
    {

        EditingHabit = habit;
        FormName = habit.Name;
        FormDescription = habit.Description;
        FormFrequency = habit.Frequency;
        FormIsQuantitative = habit.IsQuantitative;
        FormTargetValue = habit.TargetValue;
        FormUnit = habit.Unit;
        FormEstimatedTime = habit.EstimatedTime;
        FormFriction = habit.FrictionLevel;
        FormQuestCategory = habit.QuestCategory;
        FormReminderEnabled = habit.ReminderEnabled;
        FormReminderTimeString = habit.ReminderTime.HasValue
            ? habit.ReminderTime.Value.ToString("yyyy-MM-ddTHH:mm")
            : "";
        ShowForm = true;

    }

    private async Task ArchiveHabit(Habit habit)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var tracked = await db.HabitEntities.FindAsync(habit.Id);
        if (tracked is not null)
        {
            tracked.IsActive = false;
            if (!string.IsNullOrEmpty(tracked.HangfireJobId))
                await NotificationService.CancelReminderAsync(tracked.HangfireJobId);
            var notifs = await db.Notifications
            .Where(n => n.SourceEntityId == tracked.Id && !n.IsRead)
            .ToListAsync();
            foreach (var n in notifs) n.IsRead = true;
            await db.SaveChangesAsync();

        }
        await LoadData();
    }

    private async Task UnarchiveHabit(Habit habit)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var tracked = await db.HabitEntities.FindAsync(habit.Id);
        if (tracked is not null)
        {
            tracked.IsActive = true;
            await db.SaveChangesAsync();
        }
        await LoadData();
    }

    private async Task DeleteHabit(Habit habit)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var tracked = await db.HabitEntities.FindAsync(habit.Id);
        if (tracked is not null)
        {
            if (!string.IsNullOrEmpty(tracked.HangfireJobId))
                await NotificationService.CancelReminderAsync(tracked.HangfireJobId);

            var staleNotifs = await db.Notifications
                .Where(n => n.SourceEntityId == tracked.Id)
                .ToListAsync();
            db.Notifications.RemoveRange(staleNotifs);

            db.HabitEntities.Remove(tracked);
            await db.SaveChangesAsync();
        }
        await LoadData();
    }

    private void CancelForm()
    {
        ShowForm = false;
        EditingHabit = null;
        FormName = "";
        FormDescription = null;
        FormFrequency = HabitFrequency.Daily;
        FormIsQuantitative = false;
        FormTargetValue = null;
        FormUnit = null;
        FormEstimatedTime = EstimatedTime.Under15m;
        FormFriction = FrictionLevel.Low;
        FormQuestCategory = QuestCategory.Routines;
        FormReminderEnabled = false;
        FormReminderTimeString = "";
    }
}